generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // Uses a direct connection
}

// --- MODEL USER & AUTH (Wajib untuk NextAuth) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- MODEL APLIKASI KAMU ---

model Skin {
  id          String   @id @default(cuid())
  title       String
  category    String
  image       String
  description String
  downloadUrl String
  author      String   @default("Anonymous")
  downloads   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
}
// ... (Kode model User, Account, Skin yang lama biarin aja)

// --- TAMBAHAN BARU: MODEL PRESET (Paste di paling bawah) ---
model DescriptionPreset {
  id        String   @id @default(cuid())
  name      String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  skinId    String
  userName  String
  userImage String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  skin      Skin     @relation(fields: [skinId], references: [id], onDelete: Cascade)
}

model AdSetting {
  id          String   @id @default("global-ads")
  publisherId String   @default("ca-pub-XXXXXXXXXXXXX")
  slotHome    String   @default("1111111111")
  slotDetail  String   @default("2222222222")
  slotBlog    String   @default("3333333333")
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "CREATE_SKIN", "DELETE_COMMENT", "UPDATE_ADS"
  description String   @db.Text
  userName    String   @default("System")
  createdAt   DateTime @default(now())
}
